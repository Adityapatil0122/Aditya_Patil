{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "portfolio",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path');const s=http.createServer((q,r)=>{let f=path.join('.',q.url==='/'?'index.html':q.url);const ext=path.extname(f);const types={'.html':'text/html','.css':'text/css','.js':'application/javascript','.pdf':'application/pdf','.svg':'image/svg+xml'};fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end()}else{r.writeHead(200,{'Content-Type':types[ext]||'application/octet-stream'});r.end(d)}});});s.listen(3001,()=>console.log('Server on 3001'));"],
      "port": 3001
    }
  ]
}
